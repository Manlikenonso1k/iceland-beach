<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beach Resort</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Navigation */
        .sidenav {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            height: 100%;
            padding: 20px;
            box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
        }

        .sidenav h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 30px;
            text-align: center;
        }

        .sidenav a {
            text-decoration: none;
            color: white;
            font-size: 18px;
            padding: 10px 15px;
            margin-bottom: 10px;
            display: block;
            border-radius: 5px;
            transition: background-color 0.3s ease;
        }

        .sidenav a:hover {
            background-color: #34495e;
        }

        /* Main Content */
        .main {
            margin-left: 250px;
            padding: 20px;
            overflow-y: auto;
            flex: 1;
            background: linear-gradient(to bottom, #3498db, #85d6de);
        }

        .hero {
            text-align: center;
            color: white;
            margin: 50px auto;
            padding: 20px;
        }

        .hero h1 {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 24px;
            margin-top: 0;
        }

        .cards {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
            gap: 20px;
            margin-top: 50px;
        }

        .card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 300px;
            padding: 20px;
            text-align: center;
        }

        .card img {
            width: 100%;
            border-radius: 10px;
        }

        .card h2 {
            font-size: 22px;
            margin: 15px 0 10px;
        }

        .card p {
            font-size: 16px;
            color: #555;
        }

        /* Scroll to Top Button */
        .scroll-to-top {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #2c3e50;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 50%;
            font-size: 20px;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            display: none;
        }

        .scroll-to-top.show {
            display: block;
        }
    </style>
</head>
<body>
    <div class="sidenav">
        <h1>Beach Resort</h1>
        <a href="#">Home</a>
        <a href="#about">About Us</a>
        <a href="#rooms">Rooms</a>
        <a href="#activities">Activities</a>
        <a href="#contact">Contact</a>
    </div>

    <div class="main">
        <div class="hero">
            <h1>Welcome to Paradise</h1>
            <p>Experience luxury and relaxation like never before.</p>
        </div>

        <div class="cards">
            <div class="card">
                <img src="https://via.placeholder.com/300" alt="Room">
                <h2>Deluxe Rooms</h2>
                <p>Enjoy ocean views and luxurious amenities in our deluxe rooms.</p>
            </div>

            <div class="card">
                <img src="https://via.placeholder.com/300" alt="Activity">
                <h2>Fun Activities</h2>
                <p>From snorkeling to beach volleyball, there’s something for everyone.</p>
            </div>

            <div class="card">
                <img src="https://via.placeholder.com/300" alt="Dining">
                <h2>Fine Dining</h2>
                <p>Indulge in exquisite meals prepared by top chefs.</p>
            </div>
        </div>
    </div>

    <button class="scroll-to-top" id="scrollToTop">&#8593;</button>

    <script>
        const scrollToTopBtn = document.getElementById('scrollToTop');
        const mainContent = document.querySelector('.main');

        mainContent.addEventListener('scroll', () => {
            if (mainContent.scrollTop > 300) {
                scrollToTopBtn.classList.add('show');
            } else {
                scrollToTopBtn.classList.remove('show');
            }
        });

        scrollToTopBtn.addEventListener('click', () => {
            mainContent.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
</body>
</html>









